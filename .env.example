# Example environment variables for ChatAppV2
# Copy this to `.env` and fill values. Do NOT commit real secrets to git.

NODE_ENV=development
PORT=8080

# MongoDB connection string (Atlas). Replace <user>, <password>, and <dbname>.
# Example: mongodb+srv://<user>:<password>@cluster0.kjnp2wp.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.kjnp2wp.mongodb.net/<dbname>

# JWT secret used for signing tokens
JWT_SECRET=your_jwt_secret_here

# Cloudinary credentials for image uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
